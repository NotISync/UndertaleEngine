[sub_resource type="GDScript" id="GDScript_d23qb"]
script/source = "extends Enemy

@onready var torso_position = $sprite_anchor/torso.position
@onready var head_position = $sprite_anchor/head.position

var torso_offset := Vector2.ZERO
var head_offset := Vector2.ZERO
var siner := 0.0
var slam_speed = 8.0
var slam_timer := 0
var thrown := false

var animation_mode := 0

func _init():
	super._init(\"Sans\",1,1)

func _ready():
	speech_bubble.tail_side = \"left\"
	speech_bubble.tail_pos = speech_bubble.get_tail_top_left()
	can_spare = false
	sprite = $sprite_anchor/legs
	damage_anchor = $damage_anchor
	show_health_bar = false
	dodge = e_dodge.dodge
	act_options = {
		\"Check\" : check,
		}

func _process(delta):
	super._process(delta)
	siner += 30 * delta
	match(animation_mode):
		0: torso_offset = Vector2(0, 0)
		1: torso_offset = Vector2(cos(siner / 5), sin(siner / 2.5))
		2: torso_offset.y = sin(siner / 15) * 4
		3: torso_offset.y = sin(siner / 18) * 2
	
	$sprite_anchor/torso.position = torso_position + Vector2(torso_offset.x, torso_offset.y / 1.5)
	$sprite_anchor/head.position = head_position + (torso_offset + head_offset)

func _on_legs_frame_changed():
	match($sprite_anchor/legs.animation):
		\"down\":
			match($sprite_anchor/legs.frame):
				1: head_offset = Vector2(0, -4)
				2:
					head_offset = Vector2(0, 2)
					if(!thrown): vars.attack_manager.throw(0, slam_speed)
				3: 
					thrown = false
					head_offset = Vector2(0, 4)
		\"left\":
			match($sprite_anchor/legs.frame):
				1: head_offset = Vector2(2, 0)
				2: 
					head_offset = Vector2(4, 0)
					if(!thrown): vars.attack_manager.throw(90, slam_speed)
				3: 
					thrown = false
					head_offset = Vector2(-6, 0)
				4: head_offset = Vector2(-4, 0)
				5: head_offset = Vector2(-2, 0)
		\"right\":
			match($sprite_anchor/legs.frame):
				1: head_offset = Vector2(-6, 0)
				2: head_offset = Vector2(-4, 0)
				3:
					head_offset = Vector2(4, 0)
					if(!thrown): vars.attack_manager.throw(270, slam_speed)
				4: 
					thrown = false
					head_offset = Vector2(2, 0)
		\"up\":
			match($sprite_anchor/legs.frame):
				1: head_offset = Vector2(0, 4)
				2:
					head_offset = Vector2(0, -4)
					if(!thrown): vars.attack_manager.throw(180, slam_speed)
				3: 
					thrown = false
					head_offset = Vector2(0, -2)

func slam(dir, throw = true):
	thrown = !throw
	$sprite_anchor/legs.stop()
	$sprite_anchor/legs.play(dir)
	head_offset = Vector2.ZERO
	$sprite_anchor/torso.visible = false
	match(dir):
		\"down\":
			$sprite_anchor/legs.offset = Vector2(-1, -24)
			head_offset = Vector2(0, -2)
		\"left\":
			$sprite_anchor/legs.offset = Vector2(14, -12.5)
		\"right\":
			$sprite_anchor/legs.offset = Vector2(14, -12.5)
		\"up\":
			$sprite_anchor/legs.offset = Vector2(-1, -22)
			head_offset = Vector2(0, 2)
	await $sprite_anchor/legs.animation_finished
	for i in range(30):
		if($sprite_anchor/legs.is_playing()): return
		await get_tree().process_frame
	idle()

func idle():
	$sprite_anchor/legs.animation = \"default\"
	head_offset = Vector2.ZERO
	$sprite_anchor/legs.offset = Vector2(0, 0)
	$sprite_anchor/torso.visible = true

func check():
	vars.hud_manager.mode = -1
	vars.player_heart.visible = false
	match(vars.attack_manager.turn_num):
		0:
			vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* SANS 1 ATK 1 DEF\\n* The easiest enemy.(delay:0.5)\\n* Can only deal 1 damage.(pc)\"
		_:
			vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* SANS 1 ATK 1 DEF\\n* The easiest enemy.(delay:0.5)\\n* Can only deal 1 damage.(pc)* Can't keep dodging forever.(delay:0.5)\\n* Keep attacking.(pc)\"
	await vars.main_writer.done
	var attack = vars.attack_manager.pre_heal_attack()
	if vars.battle_box.margin != vars.battle_box.target:
		await vars.battle_box.resize_finished
	attack.start_attack()

func spare():
	audio.stop_music()
	vars.hud_manager.disable()
	var attack = vars.attack_manager.pre_custom_attack(load(\"res://scripts/battle/attacks/examples/attack_spare.gd\"))
	speech_bubble.visible = true
	$sprite_anchor/head.frame = 2
	speech_writer.writer_text = \"(sound:sans)...(pc)\"
	await speech_writer.done
	speech_writer.writer_text = \"(sound:sans)you're sparing me?(pc)\"
	await speech_writer.done
	$sprite_anchor/head.frame = 4
	speech_writer.writer_text = \"(sound:sans)finally.(pc)\"
	await speech_writer.done
	$sprite_anchor/head.frame = 3
	speech_writer.writer_text = \"(sound:sans)buddy.(delay:0.5)\\npal.(pc)\"
	await speech_writer.done
	$sprite_anchor/head.frame = 2
	speech_writer.writer_text = \"(sound:sans)i know how hard\\nit must be...(pc)\"
	await speech_writer.done
	speech_writer.writer_text = \"(sound:sans)to make that\\nchoice.(pc)\"
	await speech_writer.done
	speech_writer.writer_text = \"(sound:sans)to go back on\\neverything you've\\nworked up to.(pc)\"
	await speech_writer.done
	$sprite_anchor/head.frame = 0
	speech_writer.writer_text = \"(sound:sans)i want you to\\nknow...(delay:0.5)\\ni won't let it\\ngo to waste.(pc)\"
	await speech_writer.done
	$sprite_anchor/torso.frame = 1
	speech_writer.writer_text = \"(sound:sans)...(pc)\"
	await speech_writer.done
	$sprite_anchor/head.frame = 3
	speech_writer.writer_text = \"(sound:sans)c'mere,(delay:0.5) pal.(pc)\"
	await speech_writer.done
	speech_bubble.visible = false
	$sprite_anchor/head.frame = 0
	$sprite_anchor/torso.frame = 0
	if vars.battle_box.margin != vars.battle_box.target:
		await vars.battle_box.resize_finished
	attack.start_attack()
"

