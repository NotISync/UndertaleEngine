[sub_resource type="GDScript" id="GDScript_vrsuc"]
script/source = "extends Character

func _init():
	super._init(load(\"res://assets/sprite_frames/overworld/characters/sans.tres\"))

func _ready():
	super._ready()
	scale = Vector2(2,2)
	await sprite.sprite_frames_changed
	sprite.animation = \"down\"
"

[sub_resource type="GDScript" id="GDScript_nu7cm"]
script/source = "extends Interactable

var selection_index = 0

func event():
	$collision.set_deferred(\"disabled\", true)
	super.event()
	vars.player_character.input_enabled = false
	vars.player_character.cutscene = true
	vars.player_character.sprite.frame = 0
	vars.main_writer.set_font(\"sans_ow\", 28)
	vars.main_writer.writer_text = \"(face:sans/3)(sound:sans)* great,(delay:0.5) thanks.(pc)\"
	await vars.main_writer.done
	vars.main_writer.writer_text = \"(face:sans/1)(sound:sans)* so,(delay:0.5) i've been practicing\\n  this new attack i\\n  created.(pc)\"
	await vars.main_writer.done
	vars.main_writer.writer_text = \"(face:sans/2)(sound:sans)* and i thought,(delay:0.5) \\\"hey,(delay:0.25) i\\n  should really give this a\\n  test run\\\".(pc)\"
	await vars.main_writer.done
	vars.main_writer.writer_text = \"(face:sans/0)(sound:sans)* so,(delay:0.5) how about i test it on\\n  you?(pc)\"
	await vars.main_writer.done
	vars.main_writer.writer_text = \"(face:sans/3)(sound:sans)* it's only fair,(delay:0.5) considering\\n  we've never fought.(delay:0.5)\\n  Yeah            Not now(pause)\"
	await vars.main_writer.type_done
	$\"../../overworld_canvas/message_border/heart\".visible = true
	await selecting()
	$\"../../overworld_canvas/message_border/heart\".visible = false
	match(selection_index):
		0:
			vars.main_writer.writer_text = \"(face:sans/0)(sound:sans)* sweet,(delay:0.5) appreciate ya,(delay:0.5) kid.(pc)\"
			await vars.main_writer.done
		1:
			pass
	await $\"..\".move_to($\"..\".global_position + Vector2(-88, 0), 0.3)
	await $\"..\".move_to(Vector2($\"..\".global_position.x, int(vars.player_character.global_position.y) - 2), 0.25)
	$\"..\".sprite.animation = \"right\"
	vars.player_character.sprite.animation = \"left\"
	await get_tree().create_timer(.5).timeout
	await (vars.scene as OverworldRoom).go_to_battle_anim(Vector2(-233, 213) + Vector2(-39, 0))
	(vars as vars).display.change_scene(load(\"res://scenes/battles/example_battles/battle_example_whydyoujump.tscn\"),true)

func selecting():
	while(true):
		if(Input.is_action_just_pressed(\"confirm\")):
			audio.play(\"menu/menu_select\")
			if(selection_index != 1): break
		elif(Input.is_action_just_pressed(\"left\")):
			audio.play(\"menu/menu_move\")
			selection_index = wrapi(selection_index - 1,0,2)
		elif(Input.is_action_just_pressed(\"right\")):
			audio.play(\"menu/menu_move\")
			selection_index = wrapi(selection_index + 1,0,2)
		$\"../../overworld_canvas/message_border/heart\".global_position = vars.main_writer.global_position + Vector2(260 * selection_index, 80)
		await get_tree().process_frame
"

