[sub_resource type="GDScript" id="GDScript_dg0gj"]
script/source = "extends HudManager

func use(item_index : int):
	var item = settings.player_save.get_item(item_index)
	if(item is ButterscotchPie || item is SnailPie):
		audio.play(\"menu/menu_select\")
		disable()
		item.use(item_index)
		await item.done
		vars.main_writer.writer_text = \"(sound:mono2)* The smell reminded ASGORE of\\n  something...(pc)\"
		await vars.main_writer.done
		vars.main_writer.writer_text = \"(sound:mono2)* ASGORE's ATTACK dropped!(delay:0.5)\\n* ASGORE's DEFENSE dropped!(pc)\"
		vars.enemies.get_node(\"asgore\").atk -= 30
		vars.enemies.get_node(\"asgore\").def -= 30
		await vars.main_writer.done
		var attack = vars.attack_manager.pre_heal_attack()
		if vars.battle_box.margin != vars.battle_box.target:
			await vars.battle_box.resize_finished
		attack.start_attack()
	else:
		super.use(item_index)
"

