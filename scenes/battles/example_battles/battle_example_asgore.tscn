[sub_resource type="GDScript" id="GDScript_d23qb"]
script/source = "extends Enemy

@onready var torso_position = $sprite_anchor/torso.position
@onready var waist_position = $sprite_anchor/waist.position
@onready var head_position = $sprite_anchor/head.position
@onready var larm_position = $sprite_anchor/larm.position
@onready var rarm_position = $sprite_anchor/rarm.position
@onready var lforarm_position = $sprite_anchor/lforarm.position
@onready var rforarm_position = $sprite_anchor/rforarm.position
@onready var spear_position = $sprite_anchor/spear.position

var torso_offset := Vector2.ZERO
var arms_offset := Vector2.ZERO

var siner := 0.0
var talk_x := 0 if(settings.player_save.data.death_count == 0)else -1

var animation_mode := 0 :
	set(value):
		animation_mode = value
		$sprite_anchor/body.visible = value == 0
		$sprite_anchor/cape.visible = value == 1
		$sprite_anchor/legs.visible = value == 1
		$sprite_anchor/feet.visible = value == 1
		$sprite_anchor/waist.visible = value == 1
		$sprite_anchor/torso.visible = value == 1
		$sprite_anchor/head.visible = value == 1
		$sprite_anchor/larm.visible = value == 1
		$sprite_anchor/rarm.visible = value == 1
		$sprite_anchor/lforarm.visible = value == 1
		$sprite_anchor/rforarm.visible = value == 1
		$sprite_anchor/spear.visible = value == 1

func _init():
	super._init(\"Asgore\",3500,80)
	atk = 80
	
func _ready():
	speech_bubble.tail_side = \"left\"
	speech_bubble.tail_pos = speech_bubble.get_tail_top_left()
	can_spare = false
	sprite = $sprite_anchor/torso
	damage_anchor = $damage_anchor
	show_health_bar = true
	act_options = {
		\"Check\" : check,
		\"Talk\" : talk,
		}

func _process(delta):
	super._process(delta)
	siner += 30 * delta
	match(animation_mode):
		0: torso_offset = Vector2(0, 0)
		1:
			torso_offset.y = sin(siner / 15) * 4
			arms_offset.y = cos(siner / 15) * 2
	
	$sprite_anchor/torso.position = torso_position + Vector2(torso_offset.x, torso_offset.y / 1.5)
	$sprite_anchor/waist.position = waist_position + Vector2(torso_offset.x, torso_offset.y / 1.75)
	$sprite_anchor/larm.position = larm_position + arms_offset
	$sprite_anchor/rarm.position = rarm_position + arms_offset
	$sprite_anchor/lforarm.position = lforarm_position + arms_offset
	$sprite_anchor/rforarm.position = rforarm_position + arms_offset
	$sprite_anchor/head.position = head_position + torso_offset
	$sprite_anchor/spear.position = spear_position + torso_offset
	$sprite_anchor/spear/rhand.position = Vector2(25 + 35 * sin($sprite_anchor/spear.rotation + deg_to_rad(90)), 0)

	$sprite_anchor/lforarm.rotation = $sprite_anchor/lforarm.global_position.angle_to_point($sprite_anchor/spear/lhand.global_position) + deg_to_rad(90)
	$sprite_anchor/rforarm.rotation = $sprite_anchor/rforarm.global_position.angle_to_point($sprite_anchor/spear/rhand.global_position) - deg_to_rad(90)
	$sprite_anchor/lforarm.scale.y = $sprite_anchor/lforarm.global_position.distance_to($sprite_anchor/spear/lhand.global_position) / $sprite_anchor/lforarm.get_sprite_frames().get_frame_texture($sprite_anchor/lforarm.animation,$sprite_anchor/lforarm.get_frame()).get_size().y
	$sprite_anchor/rforarm.scale.y = $sprite_anchor/rforarm.global_position.distance_to($sprite_anchor/spear/rhand.global_position) / $sprite_anchor/rforarm.get_sprite_frames().get_frame_texture($sprite_anchor/rforarm.animation,$sprite_anchor/rforarm.get_frame()).get_size().y


func attack_normal(damage : float, turn := true):
	if is_instance_valid(vars.hud_manager.eye) && is_instance_valid(vars.hud_manager.eye.weapon): await vars.hud_manager.eye.weapon.hit_finish
	await get_tree().create_timer(0.0333333).timeout
	audio.play(\"battle/hit\")
	var buffer : BackBufferCopy = BackBufferCopy.new()
	var bar_smooth : NinePatchRect = NinePatchRect.new()
	var bar_max : ColorRect = ColorRect.new()
	var bar : ColorRect = ColorRect.new()
	var texture = sprite.get_sprite_frames().get_frame_texture(sprite.animation,sprite.get_frame())
	bar_smooth.texture = load(\"res://assets/sprites/battle/hud/healthbar_outline.png\")
	bar_smooth.self_modulate = Color(0, 0, 0)
	bar_smooth.patch_margin_left = 8
	bar_smooth.patch_margin_top = 8
	bar_smooth.patch_margin_right = 8
	bar_smooth.patch_margin_bottom = 8
	#bar_smooth.material = ShaderMaterial.new()
	#bar_smooth.material.shader = load(\"res://assets/effects/mask.gdshader\")
	bar_max.color = Color(.5,.5,.5,1)
	bar_max.size = Vector2(texture.get_size().x * sprite.scale.x, 15)
	bar.color = Color(.1,1,.1,1)
	bar.size = Vector2((float(current_hp) / max_hp) * texture.get_size().x * sprite.scale.x, 15)
	bar_smooth.size = bar_max.size + Vector2(4, 4)
	#buffer.z_index = 1
	bar_max.global_position = damage_anchor.global_position - bar_max.size / 2
	bar_smooth.global_position = bar_max.global_position - Vector2(2, 2)
	bar_max.add_child(bar)
	buffer.add_child(bar_max)
	buffer.add_child(bar_smooth)
	vars.scene.add_child(buffer)
	bar_max.global_position = damage_anchor.global_position - bar_max.size / 2
	bar_smooth.global_position = bar_max.global_position - Vector2(2, 2)
	current_hp = clampf(current_hp - damage,0,max_hp)
	create_tween().tween_property(bar, \"size\", Vector2((float(current_hp) / max_hp) * texture.get_size().x * sprite.scale.x, 15), .25)
	buffer.visible = show_health_bar
	var damage_text : RichTextLabel = create_text(\"[center]\"+ str(int(damage)))
	damage_text.self_modulate = Color(1, 0, 0, 1)
	damage_text.global_position = bar_max.global_position - Vector2(0,45)
	var damage_move = func():
		var drop_value = damage_anchor.global_position.y - 50.5
		var sprite_vel = -2
		while(damage_text.position.y < drop_value):
			if(is_instance_valid(damage_text)):
				sprite_vel += get_process_delta_time() * 6.0
				damage_text.position.y += sprite_vel * get_process_delta_time() * 60
			else: return
			await get_tree().process_frame
	damage_move.call()
	await get_tree().create_timer(1.3).timeout
	buffer.queue_free()
	bar_smooth.queue_free()
	bar_max.queue_free()
	bar.queue_free()
	damage_text.queue_free()
	if(turn): post_attack(damage)

func check():
	vars.hud_manager.mode = -1
	vars.player_heart.visible = false
	vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* ASGORE \" + str(atk) + \" ATK \" + str(def) + \" DEF(pc)\"
	await vars.main_writer.done
	var attack = vars.attack_manager.pre_heal_attack()
	if vars.battle_box.margin != vars.battle_box.target:
		await vars.battle_box.resize_finished
	attack.start_attack()

func talk():
	vars.hud_manager.mode = -1
	vars.player_heart.visible = false
	if(settings.player_save.player.exp > 0):
		vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* But there was nothing to\\n  say(pc)\"
	else:
		var deaths_text
		match(settings.player_save.data.death_count):
			1:
				deaths_text = \"once before\"
			2:
				deaths_text = \"twice before\"
			3:
				deaths_text = \"three times\"
			4:
				deaths_text = \"four times\"
			5:
				deaths_text = \"five times\"
			6:
				deaths_text = \"six times\"
			7:
				deaths_text = \"seven times\"
			8:
				deaths_text = \"eight times\"
			9:
				deaths_text = \"nine times\"
			_:
				deaths_text = \"too many times\\n  to count\"
		match(talk_x):
			-1:
				vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* You tell ASGORE that he's\\n  killed you \" + deaths_text + \".(pc)\"
				await vars.main_writer.done
				match(settings.player_save.data.death_count):
					1, 2, 3, 4:
						vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* He nods sadly.(pc)\"
					5, 6, 7, 8, 9:
						vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* He nods grievously.(pc)\"
					_:
						vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* He nods pitifully.(pc)\"
			0:
				vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* You quietly tell ASGORE\\n  you don't want to fight\\n  him.(pc)\"
				await vars.main_writer.done
				vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* His hands tremble for a\\n  moment.(pc)\"
			1:
				vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* You tell ASGORE that you\\n  don't want to fight him.(pc)\"
				await vars.main_writer.done
				vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* His breathing gets funny\\n  for a moment.(pc)\"
			2:
				vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* You firmly tell ASGORE to\\n  STOP fighting.(pc)\"
				await vars.main_writer.done
				vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* Recollection flashes in his\\n  eyes...(pc)\"
				await vars.main_writer.done
				vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* ASGORE's ATTACK dropped!(delay:0.5)\\n* ASGORE's DEFENSE dropped!(pc)\"
				atk -= 30
				def -= 30
			3, 4, 5, 6, 7, 8:
				vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* Seems talking won't do any\\n  more good.(pc)\"
			9:
				vars.main_writer.writer_text = \"(enable:z)(sound:mono2)* All you can do is FIGHT.(pc)\"
		talk_x = min(talk_x + 1, 9)
	await vars.main_writer.done
	var attack = vars.attack_manager.pre_heal_attack()
	if vars.battle_box.margin != vars.battle_box.target:
		await vars.battle_box.resize_finished
	attack.start_attack()

func spare():
	pass
"

