[sub_resource type="GDScript" id="GDScript_y35us"]
script/source = "extends BattleRoom

var broken_mercy_button_shards: Array[Node] = []

func _ready():
	super._ready()
	flee = false
	vars.hud_manager.serious_mode = true
	settings.player_save.player.lv = 1
	settings.player_save.player.current_hp = 20
	settings.player_save.player.max_hp = 20
	settings.player_save.player.atk = 80
	settings.player_save.player.def = 0
	settings.player_save.player.exp = 0
	settings.player_save.player.weapon = \"stick\"
	settings.player_save.player.armor = \"bandage\"
	settings.player_save.player.gold = 0
	settings.player_save.player.kills = 0
	settings.player_save.inventory = [ #Don't erase indexes from this Array!!!!
		\"butterscotch_pie\",
		\"\",
		\"\",
		\"\",
		\"\",
		\"\",
		\"\",
		\"\"
		]
	await intro(false, settings.player_save.data.death_count>0)
	#vars.main_writer.writer_text = \"\"
	#vars.hud_manager.disable()
	#var attack = vars.attack_manager.pre_custom_attack(vars.attack_manager.heal_attacks[0])
	#await attack.start_attack()

func intro(skip := false, true_skip := false):
	var enemy = vars.enemies.get_node(\"asgore\")
	vars.hud_manager.disable()
	if(!skip):
		#audio.play_music(\"music/mus_bergentruckung\")
		vars.battle_box.material.set_shader_parameter(\"fill\", Vector4(0, 0, 0, 0))
		vars.battle_box.material.set_shader_parameter(\"border\", Vector4(1, 1, 1, 0))
		vars.battle_box.material.set_shader_parameter(\"outline\", Vector4(0, 0, 0, 0))
		vars.battle_box.material.set_shader_parameter(\"inline\", Vector4(0, 0, 0, 0))
		#vars.main_writer.writer_text = \"(disable:x)(speed:0.049999995)* (lp)A strange light fills the\\n  room.(rp)(delay:2)(clear)\"
		#await vars.main_writer.done
		#vars.main_writer.writer_text = \"* (lp)Twilight is shining through\\n  the barrier.(rp)(delay:2)(clear)\"
		#await vars.main_writer.done
		#vars.main_writer.writer_text = \"* (lp)It seems your journey is\\n  finally over.(rp)(delay:2)(clear)\"
		#await vars.main_writer.done
		#vars.main_writer.writer_text = \"     * (lp)You're filled with\\n          DETERMINATION.(rp)(delay:2.5)(clear)\"
		#await vars.main_writer.done
		#enemy.speech_bubble.tail_texture(load(\"res://assets/sprites/battle/speech_bubble/speech_bubble_tail_small.png\"))
		#enemy.speech_bubble.offset_right = -14
		#enemy.speech_bubble.offset_bottom = 68
		#enemy.speech_bubble.tail_pos = enemy.speech_bubble.get_tail_middle()
		#enemy.speech_bubble.visible = true
		#enemy.speech_writer.writer_text = \"(disable:x)(speed:0.09999999)(sound:asgore)Human...(pc)\"
		#await enemy.speech_writer.done
		#enemy.get_node(\"sprite_anchor/head\").frame = 1
		#enemy.speech_writer.writer_text = \"(speed:0.09999999)(sound:asgore)It was\\nnice to\\nmeet\\nyou.(pc)\"
		#await enemy.speech_writer.done
		#enemy.get_node(\"sprite_anchor/head\").frame = 0
		#enemy.speech_writer.writer_text = \"(speed:0.09999999)(sound:asgore)Goodbye.(pc)\"
		#await enemy.speech_writer.done
		enemy.get_node(\"sprite_anchor/head\").visible = false
		enemy.speech_bubble.visible = false
		vars.main_writer.speed = 0.03333333
		enemy.get_node(\"sprite_anchor/body\").animation = &\"intro\"
		enemy.get_node(\"sprite_anchor/body\").frame = 0
		audio.play(\"battle/snd_spearappear\")
		var body_afterimage = load(\"res://objects/battle/afterimage.tscn\").instantiate()
		body_afterimage.sprite = enemy.get_node(\"sprite_anchor/body\")
		enemy.get_parent().add_child(body_afterimage)
		enemy.get_parent().move_child(body_afterimage, enemy.get_index())
		var asgore_moved = create_tween()
		asgore_moved.tween_method(func(v): enemy.position.x = v, 320, 180, 0.2)
		await get_tree().create_timer(.5, false).timeout
		body_afterimage.visible = false
		enemy.get_node(\"sprite_anchor/body\").play(&\"intro\")
		vars.black_screen.color = Color(1, 1, 1, 0)
		vars.black_screen.visible = true
		await get_tree().create_timer(1/7.5, false).timeout
		audio.play(\"battle/mus_sfx_cinematiccut\")
		var flash_in = create_tween()
		flash_in.finished.connect(
			func(): 
				vars.display.screen_shake(10, 1)
				create_tween().tween_method(func(v): vars.black_screen.color.a = v, 1.0, 0.0, 0.15))
		flash_in.tween_method(func(v): vars.black_screen.color.a = v, 0.0, 1.0, 0.05)
		await get_tree().create_timer(1.5, false).timeout
		audio.play(\"battle/snd_spearappear\")
		enemy.get_node(\"sprite_anchor/body\").self_modulate = Color(0, 0, 0)
		var temp_buttons : Array[Node] = []
		for i in range(vars.hud_manager.display.buttons.size()):
			var button = Sprite2D.new()
			button.texture = load(\"res://assets/sprites/battle/hud/buttons/\" + vars.hud_manager.display.buttons[i].get_name() + \"/0.png\")
			button.material = ShaderMaterial.new()
			button.material.shader = load(\"res://assets/effects/black_and_white_.gdshader\")
			button.material.set_shader_parameter(\"invert\", true)
			button.global_position = vars.hud_manager.display.buttons[i].global_position
			vars.scene.add_child(button)
			temp_buttons.append(button)
		$background.visible = true
		vars.hud_manager.visible = false
		enemy.get_node(\"sprite_anchor/body\").frame = 0
		body_afterimage.visible = true
		var spear = Sprite2D.new()
		spear.offset = Vector2(58, 0)
		spear.position = Vector2(42, 40)
		spear.scale = Vector2(2, 2)
		spear.self_modulate = Color(1, 0, 0)
		spear.texture = enemy.get_node(\"sprite_anchor/spear\").get_sprite_frames().get_frame_texture(enemy.get_node(\"sprite_anchor/spear\").animation,enemy.get_node(\"sprite_anchor/spear\").get_frame())
		enemy.add_child(spear)
		var spear_afterimage = load(\"res://objects/battle/afterimage.tscn\").instantiate()
		spear_afterimage.sprite = spear
		enemy.add_child(spear_afterimage)
		enemy.move_child(spear_afterimage, spear.get_index())
		create_tween().tween_method(func(v): spear.rotation_degrees = v, 0, 90, .5).set_trans(Tween.TRANS_QUAD).set_ease(Tween.EASE_OUT)
		asgore_moved = create_tween()
		asgore_moved.tween_method(func(v): enemy.position.x = v, 180, 514, 0.5).set_trans(Tween.TRANS_QUAD).set_ease(Tween.EASE_OUT)
		var spear_aim = create_tween()
		spear_aim.finished.connect(func(): create_tween().tween_method(func(v): spear.position.y = v, -250, 800, .25))
		spear_aim.tween_method(func(v): spear.position.y = v, 40, -250, 1.5).set_trans(Tween.TRANS_QUART).set_ease(Tween.EASE_OUT)
		await get_tree().create_timer(1.55, false).timeout
		create_tween().tween_method(func(v): vars.black_screen.color.a = v, 0.0, 1.0, .5)
		var broken_mercy_button = load(\"res://objects/battle/broken_mercy_button.tscn\").instantiate()
		broken_mercy_button.global_position = temp_buttons[3].global_position
		for i in broken_mercy_button.get_children():
			i.modulate = Color(0, 0, 0)
			match(int(float(str(i.get_name())))):
				0, 1, 6, 8:
					i.set_meta(\"vx\", randf_range(-700, -500))
					i.set_meta(\"vr\", -200)
				3, 4, 5, 7:
					i.set_meta(\"vx\", randf_range(500, 700))
					i.set_meta(\"vr\", 200)
				_:
					i.set_meta(\"vx\", [randf_range(-500, -800), randf_range(500, 800)].pick_random())
					i.set_meta(\"vr\", (200 if i.get_meta(\"vx\") > 0 else -200))
			i.set_meta(\"vy\", randf_range(-300, -400))
			i.reparent(vars.scene)
			broken_mercy_button_shards.append(i)
		temp_buttons[3].queue_free()
		temp_buttons.remove_at(3)
		audio.play(\"battle/mus_sfx_swipe\")
		await get_tree().create_timer(.1, false).timeout
		vars.display.screen_shake(10, 1)
		audio.play(\"battle/break2\")
		await get_tree().create_timer(.65, false).timeout
		create_tween().tween_method(func(v): vars.black_screen.color = v, Color(1, 1, 1), Color(0, 0, 0), .5)
		await get_tree().create_timer(1, false).timeout
		for i in temp_buttons:
			i.queue_free()
		temp_buttons.clear()
		for i in broken_mercy_button_shards:
			i.queue_free()
		broken_mercy_button_shards.clear()
		spear.queue_free()
		spear_afterimage.queue_free()
		body_afterimage.queue_free()
	vars.black_screen.visible = true
	audio.play_music(\"music/mus_vsasgore\")
	enemy.position = Vector2(320, 75)
	enemy.animation_mode = 1
	enemy.get_node(\"sprite_anchor/head\").frame = 2
	enemy.get_node(\"sprite_anchor/body\").self_modulate = Color(1, 1, 1)
	vars.hud_manager.get_node(\"buttons/mercy\").free()
	vars.hud_manager.display.buttons = vars.hud_manager.get_node(\"buttons\").get_children()
	vars.hud_manager.visible = true
	$background.visible = false
	$gradient.visible = true
	$particles.visible = true
	vars.battle_box.material.set_shader_parameter(\"fill\", Vector4(0, 0, 0, .75))
	vars.battle_box.material.set_shader_parameter(\"border\", Vector4(1, 1, 1, 1))
	vars.battle_box.material.set_shader_parameter(\"outline\", Vector4(0, 0, 0, 1))
	vars.battle_box.material.set_shader_parameter(\"inline\", Vector4(0, 0, 0, 1))
	if(!true_skip):
		await get_tree().create_timer(60/58, false).timeout
	vars.hud_manager.reset()
	await get_tree().process_frame
	await get_tree().process_frame
	vars.black_screen.visible = false

func _process(delta: float) -> void:
	if !broken_mercy_button_shards.is_empty(): for i in broken_mercy_button_shards:
		var vx: float = i.get_meta(\"vx\")
		var vy: float = i.get_meta(\"vy\")
		var vr: float = i.get_meta(\"vr\")
		
		i.position += Vector2(vx, vy) * delta
		i.rotation_degrees += vr * delta
		
		i.set_meta(\"vx\", vx + cos(i.rotation + deg_to_rad(90)) * delta)
		i.set_meta(\"vy\", vy + 1000 * delta)
"

