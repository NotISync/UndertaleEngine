[sub_resource type="GDScript" id="GDScript_qjlpj"]
script/source = "extends Sprite2D

@onready var parent = $\"..\"
@onready var knob_mask = $\"../mask/knob\"
@onready var buttons = $\"../buttons\".get_children()
@onready var buttons_hold = $\"../buttons_hold\".get_children()

var pressing = false
var button_range = 400
var maxlength = 50
var deadzone = 40

func _process(delta):
	var button_size = Vector2(59, 118)
	buttons_hold[0].shape.size = Vector2((button_range-deadzone)/2, button_range)
	buttons_hold[0].position = Vector2((button_range+deadzone)/4, 0)
	buttons_hold[1].shape.size = Vector2((button_range-deadzone)/2, button_range)
	buttons_hold[1].position = Vector2(-((button_range+deadzone)/4), 0)
	buttons_hold[2].shape.size = Vector2(button_range, (button_range-deadzone)/2)
	buttons_hold[2].position = Vector2(0, (button_range+deadzone)/4)
	buttons_hold[3].shape.size = Vector2(button_range, (button_range-deadzone)/2)
	buttons_hold[3].position = Vector2(0, -((button_range+deadzone)/4))
	for i in buttons_hold:
		i.visible = pressing
	if(pressing&&get_global_mouse_position().distance_to(parent.global_position) <= button_range+maxlength):
		maxlength = 50*$\"..\".scale.x
		if(get_global_mouse_position().distance_to(parent.global_position) <= maxlength):
			global_position = get_global_mouse_position()
		else:
			var angle = parent.global_position.angle_to_point(get_global_mouse_position())
			global_position.x = parent.global_position.x + cos(angle)*maxlength
			global_position.y = parent.global_position.y + sin(angle)*maxlength
		calculateVector()
	else:
		pressing = false
		global_position = parent.global_position
		parent.posVector = Vector2(0, 0)
	knob_mask.global_position = global_position
func calculateVector():
	if(abs((global_position.x - parent.global_position.x)) >= deadzone):
		parent.posVector.x = (global_position.x - parent.global_position.x)/maxlength
	if(abs((global_position.y - parent.global_position.y)) >= deadzone):
		parent.posVector.y = (global_position.y - parent.global_position.y)/maxlength

func _on_button_button_down():
	pressing = true

func _on_button_button_up():
	pressing = false
"

