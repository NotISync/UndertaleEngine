script/source = "extends BattleRoom

var intro_skip = settings.player_save.data.death_count>0

func _ready():
	super._ready()
	flee = false
	vars.hud_manager.serious_mode = true
	vars.player_heart.jump_speed_multiplier = 1.75
	settings.player_save.player.lv = 19
	settings.player_save.player.current_hp = 92
	settings.player_save.player.max_hp = 92
	settings.player_save.player.atk = 36
	settings.player_save.player.def = 4
	settings.player_save.player.exp = 50000
	settings.player_save.player.weapon = \"real_knife\"
	settings.player_save.player.armor = \"the_locket\"
	settings.player_save.player.gold = 3094
	settings.player_save.player.kills = 107
	settings.player_save.inventory = [ #Don't erase indexes from this Array!!!!
		\"butterscotch_pie\",
		\"instant_noodles\",
		\"face_steak\",
		\"legendary_hero\",
		\"legendary_hero\",
		\"legendary_hero\",
		\"legendary_hero\",
		\"legendary_hero\"
		]
	intro(true)#intro(intro_skip)
	#vars.hud_manager.show_kr_text = true
	#audio.play_music(\"music/harderlovania\", audio.global_volume, 1, randf_range(0, 177))
	#vars.enemies.get_node(\"sans\").animation_mode = 1
	#vars.hud_manager.reset()
	#vars.hud_manager.disable()
	#var attack = vars.attack_manager.pre_custom_attack(load(\"res://scripts/battle/attacks/examples/attack_heal_2.gd\"))
	#attack.start_attack()

func intro(skip : bool = false):
	intro_skip = skip
	audio.play_music(\"music/mus_birdnoise\")
	vars.hud_manager.disable()
	vars.battle_box.visible = false
	var enemy = vars.enemies.get_node(\"sans\")
	enemy.get_node(\"sprite_anchor/head\").frame = 2
	await get_tree().create_timer(.4).timeout
	enemy.speech_bubble.visible = true
	if(skip):
		enemy.speech_writer.writer_text = \"(disable:x)(speed:0.0666667)(sound:sans)ready?(pc)\"
		await enemy.speech_writer.done
		enemy.speech_bubble.visible = false
		vars.attack_manager.black_screen(0.05)
		audio.stop_music()
		vars.hud_manager.show_kr_text = true
		vars.battle_box.visible = true
		vars.player_heart.visible = true
		enemy.get_node(\"sprite_anchor/head\").frame = 1
		var attack = vars.attack_manager.pre_custom_attack(load(\"res://scripts/battle/attacks/examples/attack_intro.gd\"))
		attack.start_attack()
	else:
		enemy.speech_writer.writer_text = \"(disable:x)(speed:0.0666667)(sound:sans)it's a beautiful\\nday outside.(pc)\"
		await enemy.speech_writer.done
		enemy.speech_writer.writer_text = \"(speed:0.0666667)(sound:sans)birds are singing,(delay:0.5)\\nflowers are blooming...(pc)\"
		await enemy.speech_writer.done
		enemy.speech_writer.writer_text = \"(speed:0.0666667)(sound:sans)on days like these,(delay:0.5)\\nkids like you...(pc)\"
		await enemy.speech_writer.done
		enemy.speech_bubble.visible = false
		await get_tree().create_timer(0.05).timeout
		vars.attack_manager.black_screen(0.1)
		audio.stop_music()
		vars.hud_manager.show_kr_text = true
		vars.battle_box.visible = true
		vars.player_heart.visible = true
		await get_tree().create_timer(0.05).timeout
		enemy.get_node(\"sprite_anchor/head\").frame = 1
		var attack = vars.attack_manager.pre_custom_attack(load(\"res://scripts/battle/attacks/examples/attack_intro.gd\"))
		await get_tree().create_timer(0.1).timeout
		enemy.speech_bubble.tail_texture(load(\"res://assets/sprites/battle/speech_bubble/speech_bubble_tail_small.png\"))
		enemy.speech_bubble.offset_right = -16
		enemy.speech_bubble.offset_bottom = 68
		enemy.speech_bubble.tail_pos = enemy.speech_bubble.get_tail_middle()
		enemy.speech_bubble.visible = true
		enemy.speech_writer.get(\"theme_override_fonts/normal_font\").set_base_font(load(\"res://assets/fonts/dialogue.ttf\"))
		enemy.speech_writer.get(\"theme_override_fonts/normal_font\").spacing_glyph = 0
		enemy.speech_writer.get(\"theme_override_fonts/normal_font\").spacing_space = 0
		enemy.speech_writer.get(\"theme_override_fonts/normal_font\").spacing_bottom = 4
		enemy.speech_writer.writer_text = \"(speed:0.13333333)(size:13)(sound:none)Should\\nbe\\nburning\\nin hell.(pc)\"
		await enemy.speech_writer.done
		enemy.speech_bubble.visible = false
		attack.start_attack()
	await vars.attack_manager.attack_done
	audio.play_music(\"music/harderlovania\")
"

