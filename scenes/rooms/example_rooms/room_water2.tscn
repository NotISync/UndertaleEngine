[sub_resource type="GDScript" id="GDScript_ch82y"]
script/source = "extends OverworldRoom

var jumped = false

func _ready():
	room_sprite = $room
	room_changers = [$room_changer, $room_changer2]
	room_spawnpoint = $spawn_point
	room_savepos = $save_pos
	await super._ready()
	if(audio.music != audio.references[\"music/sans\"] or not audio.music.playing): audio.play_music(\"music/sans\")
	match(settings.player_save.data.position):
		room_savepos.position: pass
		room_spawnpoint.position: pass
		_:
			for i in room_changers:
				if(settings.player_save.data.position == i.player_spawn.global_position):
					return
			$trigger_cutscene/collision.set_deferred(\"disabled\", true)
			$sans/Interactable2/collision.set_deferred(\"disabled\", false)

func start_cutscene():
	vars.player_character.input_enabled = false
	vars.player_character.cutscene = true
	vars.player_character.sprite.frame = 0
	#vars.player_character.sprite.animation = \"up\"
	#vars.player_character.snap_camera = false
	#$sans.global_position.y = vars.player_character.global_position.y
	#await get_tree().create_timer(1).timeout
	#create_tween().tween_property(vars.scene_cam,\"global_position\",vars.scene_cam.global_position + Vector2(200,0),1.5)
	#await get_tree().create_timer(.5).timeout
	#$sans.visible = true
	#await get_tree().create_timer(1.5).timeout
	#vars.main_writer.event.connect((func(): audio.play_music(\"music/sans\")),4)
	#vars.main_writer.writer_text = \"(font:mono)(size:32)(sound:none)(disable:x)* Human. (delay:.5)You are a bad guy.(pc)(event)(sound:sans)(face:sans/normal)(enable:x)* just kidding.(pc)* unfortunately i am\\n  gonna need to \\n  fight you though.(pc)* apparently we need\\n  to do a showcase.(pc)\"
	
	vars.main_writer.set_font(\"sans_ow\",28)
	vars.main_writer.writer_text = \"(face:sans/0)(sound:sans)* hey kid,(delay:0.5) come here for a\\n  sec.(pc)\"
	await vars.main_writer.done
	vars.player_character.input_enabled = true
	vars.player_character.cutscene = false
	#vars.main_writer.writer_text = \"(face:sans/1)* you've been busy,(delay:0.5)\\n  huh?(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"* ...(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"(face:sans/0)* so,(delay:0.5) i've got a\\n  question for ya.(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"(face:sans/5)* do you think even\\n  the worst person can\\n  change...?(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"* that everybody can be\\n  a good person,(delay:0.5) if\\n  they just try?(pc)\"
	#await vars.main_writer.done
	#player_character.x = 0.175
	#await get_tree().create_timer(.25).timeout
	#player_character.x = 0
	#await get_tree().create_timer(.5).timeout
	#vars.main_writer.writer_text = \"* heh heh heh heh...(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"(face:sans/1)* all right.(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"(face:sans/5)* well,(delay:0.5) here's a better\\n  question.(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"(face:sans/6)* do you wanna have\\n  a bad time?(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"(face:sans/5)* 'cause if you take\\n  another step\\n  forward...(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"(face:sans/6)* you are REALLY not\\n  going to like what\\n  happens next.(pc)\"
	#await vars.main_writer.done
	#player_character.x = 0.175
	#await get_tree().create_timer(.25).timeout
	#player_character.x = 0
	#await get_tree().create_timer(.5).timeout
	#vars.main_writer.writer_text = \"(face:sans/5)* welp.(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"* sorry,(delay:0.5) old lady.(pc)\"
	#await vars.main_writer.done
	#vars.main_writer.writer_text = \"* this is why i never\\n  make promises.(pc)\"
	#await (vars as vars).main_writer.done
	#await (vars.scene as OverworldRoom).go_to_battle_anim(Vector2(0, 80))
	#(vars as vars).display.change_scene(load(\"res://scenes/battles/example_battles/battle_example.tscn\"),true)

func get_place_text() -> String:
	return \"Waterfall - Checkpoint\"
"

