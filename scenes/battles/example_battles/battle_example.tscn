[sub_resource type="GDScript" id="GDScript_7hybg"]
script/source = "extends AttackManager

var encounter_text = \"(disable:z)(sound:mono2)* Error!\"

func _init():
	attacks = [load(\"res://scripts/battle/attacks/examples/attack_example_1.gd\"), load(\"res://scripts/battle/attacks/examples/attack_example_2.gd\"), load(\"res://scripts/battle/attacks/examples/attack_example_3.gd\")]
	heal_attacks = [load(\"res://scripts/battle/attacks/examples/attack_heal_1.gd\"), load(\"res://scripts/battle/attacks/examples/attack_heal_2.gd\")]

func _ready():
	super._ready()
	attack_done.connect(func(): set_encounter_text())

func set_writer_text():
	vars.main_writer.writer_text = encounter_text

func set_encounter_text():
	match(vars.attack_manager.turn_num):
		0:
			encounter_text = \"(disable:z)(sound:mono2)* You feel like you're going to\\n  have a bad time.\"
		4:
			encounter_text = \"(disable:z)(sound:mono2)* Sans's movements grow a little\\n  wearier.\"
		9:
			encounter_text = \"(disable:z)(sound:mono2)* Sans's movements seem to be slower.\"
		13:
			encounter_text = \"(disable:z)(sound:mono2)* Sans is sparing you.\"
		_:
			encounter_text = \"(disable:z)(sound:mono2)* Just keep attacking.\"
			if(settings.player_save.player.current_kr>=0&&10>=settings.player_save.player.current_kr):
				encounter_text = \"(disable:z)(sound:mono2)* You felt your sins crawling on\\n  your back.\"
			elif(settings.player_save.player.current_kr>10&&20>=settings.player_save.player.current_kr):
				encounter_text = \"(disable:z)(sound:mono2)* You felt your sins weighing on\\n  your neck.\"
			elif(settings.player_save.player.current_kr>20&&30>=settings.player_save.player.current_kr):
				encounter_text = \"(disable:z)(sound:mono2)* KARMA coursing through your\\n  veins.\"
			elif(settings.player_save.player.current_kr>30):
				encounter_text = \"(disable:z)(sound:mono2)* Doomed to death of KARMA!\"
"

