[sub_resource type="GDScript" id="GDScript_hgwku"]
script/source = "extends DialougeManager

func start():
	var enemy = vars.enemies.get_node(\"sans\")
	match(vars.attack_manager.turn_num):
		0:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 3
			enemy.get_node(\"sprite_anchor/torso\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)what?(delay:0.5)\\nyou think i'm just\\ngonna stand there\\nand take it?(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.get_node(\"sprite_anchor/torso\").frame = 0
		1:
			enemy.speech_bubble.visible = true
			enemy.speech_writer.writer_text = \"(sound:sans)our reports showed\\na massive anomaly\\nin the timespace\\ncontinuum.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_writer.writer_text = \"(sound:sans)timelines jumping\\nleft and right,\\nstopping and\\nstarting...(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
		2:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.speech_writer.writer_text = \"(sound:sans)until suddenly,(delay:0.5)\\neverything ends.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
		3:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.speech_writer.writer_text = \"(sound:sans)heh heh heh...(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)that's your fault,(delay:0.5)\\nisn't it?(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
		4:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 4
			enemy.speech_writer.writer_text = \"(sound:sans)you can't understand\\nhow this feels.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
		5:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.speech_writer.writer_text = \"(sound:sans)knowing that one\\nday,(delay:0.5) without any\\nwarning...(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 6
			enemy.speech_writer.writer_text = \"(sound:sans)it's all going to\\nbe reset.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
		6:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 6
			enemy.get_node(\"sprite_anchor/torso\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)look.(delay:0.5)\\ni gave up trying\\nto go back a long\\ntime ago.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.get_node(\"sprite_anchor/torso\").frame = 0
		7:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.get_node(\"sprite_anchor/torso\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)and getting to the\\nsurface doesn't\\nreally appeal\\nanymore,(delay:0.5) either.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.get_node(\"sprite_anchor/torso\").frame = 0
		8:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.get_node(\"sprite_anchor/torso\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)cause even if we\\ndo...(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)we'll just end up\\nright back here,(delay:0.5)\\nwithout any memory\\nof it,(delay:0.5) right?(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.get_node(\"sprite_anchor/torso\").frame = 0
		9:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 4
			enemy.get_node(\"sprite_anchor/torso\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)to be blunt...(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.speech_writer.writer_text = \"(sound:sans)it makes it kind\\nof hard to give\\nit my all.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.get_node(\"sprite_anchor/torso\").frame = 0
		10:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 4
			enemy.get_node(\"sprite_anchor/torso\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)... or is that just\\na poor excuse for\\nbeing lazy...?(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 3
			enemy.speech_writer.writer_text = \"(sound:sans)hell if i know.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.get_node(\"sprite_anchor/torso\").frame = 0
		11:
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.get_node(\"sprite_anchor/torso\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)all i know is...(delay:0.5)\\nseeing what comes\\nnext...(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 6
			enemy.speech_writer.writer_text = \"(sound:sans)i can't afford not\\nto care anymore.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.get_node(\"sprite_anchor/torso\").frame = 0
		12: #MERCY
			audio.stop_music()
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head/sweat\").frame = 1
			enemy.get_node(\"sprite_anchor/head/sweat\").visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 6
			enemy.speech_writer.writer_text = \"(sound:sans)ugh...(delay:0.5)\\nthat being said...(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 4
			enemy.speech_writer.writer_text = \"(sound:sans)you,(delay:0.5) uh,(delay:0.5) really\\nlike swinging that\\nthing around,(delay:0.5)\\nhuh?(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.speech_writer.writer_text = \"(sound:sans)...(pc)\"
			audio.play_music(\"music/mus_chokedup\")
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.speech_writer.writer_text = \"(sound:sans)listen.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_writer.writer_text = \"(sound:sans)i know you didn't\\nanswer me before,(delay:0.5)\\nbut...(pc)\"
			await enemy.speech_writer.done
			enemy.speech_writer.writer_text = \"(sound:sans)somewhere in\\nthere.(delay:0.5)\\ni can feel it.(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.speech_writer.writer_text = \"(sound:sans)there's a glimmer\\nof a good person\\ninside of you.(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.speech_writer.writer_text = \"(sound:sans)the memory of\\nsomeone who once\\nwanted to do the\\nright thing.(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 4
			enemy.speech_writer.writer_text = \"(sound:sans)someone who,(delay:0.5) in\\nanother time,(delay:0.5)\\nmight have even\\nbeen...(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.speech_writer.writer_text = \"(sound:sans)a friend?(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 3
			enemy.speech_writer.writer_text = \"(sound:sans)c'mon,(delay:0.5) buddy.(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.speech_writer.writer_text = \"(sound:sans)do you remember\\nme?(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.speech_writer.writer_text = \"(sound:sans)please,(delay:0.5) if you're\\nlistening...(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 6
			enemy.speech_writer.writer_text = \"(sound:sans)let's forget all\\nthis,(delay:0.5) ok?(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 3
			enemy.speech_writer.writer_text = \"(sound:sans)just lay down\\nyour weapon,(delay:0.5) and...(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 2
			enemy.speech_writer.writer_text = \"(sound:sans)well,(delay:0.5) my job\\nwill be a lot\\neasier.(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.can_spare = true
			vars.attack_manager.attacks = []
			vars.attack_manager.heal_attacks = []
			done.emit()
			vars.attack_manager.current_attack.end_attack()
		13:
			audio.stop_music()
			enemy.can_spare = false
			enemy.speech_bubble.visible = true
			enemy.get_node(\"sprite_anchor/head\").frame = 3
			enemy.get_node(\"sprite_anchor/torso\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)welp,(delay:0.5) it was\\nworth a shot.(pc)\"
			await enemy.speech_writer.done
			enemy.get_node(\"sprite_anchor/head\").frame = 1
			enemy.speech_writer.writer_text = \"(sound:sans)guess you like\\ndoing things the\\nhard way,(delay:0.5) huh?(pc)\"
			await enemy.speech_writer.done
			enemy.speech_bubble.visible = false
			enemy.get_node(\"sprite_anchor/head\").frame = 0
			enemy.get_node(\"sprite_anchor/torso\").frame = 0
			audio.play_music(\"music/harderlovania\")
			vars.attack_manager.attacks = []
			vars.attack_manager.heal_attacks = []
	await get_tree().process_frame
	done.emit()
"

